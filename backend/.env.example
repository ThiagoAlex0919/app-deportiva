# Copiar a .env y completar. NUNCA commitear el .env real.
# PostgreSQL (Prisma 7: la URL vive aquí, no en schema.prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/app_deportivo?schema=public"
# Puerto HTTP del monolito
PORT=3000
# Secreto de firma del access token JWT (generar uno aleatorio largo)
JWT_SECRET="cambiame-por-un-secreto-aleatorio-largo"
# TTL del access token (opcional, default 15m)
JWT_ACCESS_TTL="15m"
# API key del backoffice (POST /admin/events/:id/finish) — doc 10
ADMIN_API_KEY="cambiame-por-una-key-aleatoria"
# Token de football-data.org (doc 12) — registrarse en football-data.org/client/register
FOOTBALL_DATA_TOKEN="tu-token-de-football-data"
